---
import Layout from '../layouts/Layout.astro';
import TrustStrip from '../components/TrustStrip.astro';
import Process from '../components/Process.astro';
import Products from '../components/Products.astro';
import WhyUs from '../components/WhyUs.astro';
import Showroom from '../components/Showroom.astro';
import MeetJackson from '../components/MeetJackson.astro';
import Reviews from '../components/Reviews.astro';
import ServiceAreas from '../components/ServiceAreas.astro';
import FinalCta from '../components/FinalCta.astro';
import Gallery from '../components/Gallery.astro';
import Brands from '../components/Brands.astro';
import LeadForm from '../components/LeadForm.tsx';
import Faq from '../components/Faq.tsx';
import { localBusiness, serviceSchema, faqSchema } from '../data/schema';

const title = 'Blinds Geelong | Free In-Home Measure & Quote | Bay City Blinds';
const description = 'Bay City Blinds brings the showroom to you. Free in-home measure & quote for roller blinds, shutters, Venetians & curtains across Geelong, Surf Coast, Bellarine & western Melbourne. Local & family-owned since 2020.';
const schemas = [localBusiness(), serviceSchema(), faqSchema()];
---
<Layout title={title} description={description} path="/" schemas={schemas}>
  <section class="heroC">
    <img class="heroC-img" src="/jackson-hero-bleed.webp" width="1122" height="880" fetchpriority="high" alt="Jackson from Bay City Blinds giving a thumbs up in front of his branded mobile showroom van in Geelong" />
    <div class="heroC-grad" aria-hidden="true"></div>
    <div class="wrap heroC-grid">
      <div class="heroC-copy reveal">
        <p class="eyebrow">Blinds · Shutters · Curtains — Geelong &amp; the Bellarine</p>
        <h1>The showroom that <span class="hl">comes to you</span> — measured, quoted, no pressure.</h1>
        <p class="sub">Skip the shop. See real samples against your own walls and light, with a clear fixed price before you decide anything.</p>
        <p class="trust-line"><b>Jackson &amp; his installers are the faces of the business</b> — police-checked locals with years of 5-star reviews, not a franchise that arrived last year.</p>
        <div class="trust-chips">
          <span class="chip"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.9 6.3 6.9.6-5.2 4.6 1.6 6.8L12 17.3 5.8 20.9l1.6-6.8L2.2 8.9l6.9-.6z"/></svg>5.0 · years of reviews</span>
          <span class="chip"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>Police &amp; security checked</span>
          <span class="chip"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 11l9-8 9 8"/><path d="M5 10v10h14V10"/></svg>Local — not a franchise</span>
          <span class="chip"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 8v4l3 2"/><circle cx="12" cy="12" r="9"/></svg>Evenings &amp; weekends</span>
        </div>
      </div>
      <aside id="quote" class="heroC-form reveal">
        <LeadForm client:load />
      </aside>
    </div>
  </section>

  <TrustStrip />
  <Process />
  <Products />
  <Brands />
  <WhyUs />
  <Showroom />
  <MeetJackson />
  <Gallery />
  <Reviews />
  <ServiceAreas />

  <section class="block" id="faq">
    <div class="wrap">
      <div class="sec-head reveal">
        <p class="eyebrow">Good to know</p>
        <h2>Frequently asked questions</h2>
      </div>
      <Faq client:visible />
    </div>
  </section>

  <FinalCta />
</Layout>
