---
import Layout from '../layouts/Layout.astro';
import TrustStrip from '../components/TrustStrip.astro';
import Process from '../components/Process.astro';
import Products from '../components/Products.astro';
import WhyUs from '../components/WhyUs.astro';
import Showroom from '../components/Showroom.astro';
import MeetJackson from '../components/MeetJackson.astro';
import Reviews from '../components/Reviews.astro';
import ServiceAreas from '../components/ServiceAreas.astro';
import FinalCta from '../components/FinalCta.astro';
import Gallery from '../components/Gallery.astro';
import Brands from '../components/Brands.astro';
import LeadForm from '../components/LeadForm.tsx';
import Faq from '../components/Faq.tsx';
import { localBusiness, serviceSchema, faqSchema } from '../data/schema';

const title = 'Blinds Geelong | Free In-Home Measure & Quote | Bay City Blinds';
const description = 'Bay City Blinds brings the showroom to you. Free in-home measure & quote for roller blinds, shutters, Venetians & curtains across Geelong, Surf Coast, Bellarine & western Melbourne. Local & family-owned since 2020.';
const schemas = [localBusiness(), serviceSchema(), faqSchema()];
---
<Layout title={title} description={description} path="/" schemas={schemas}>
  <section class="hero heroX">
    <div class="wrap heroX-grid2">
      <div class="hx-copy reveal">
        <p class="eyebrow">Blinds · Shutters · Curtains — Geelong &amp; the Bellarine</p>
        <h1>Free in-home <span class="hl">measure &amp; quote</span> — right across Geelong.</h1>
        <p class="sub">Jackson brings the samples to your living room, measures every window properly, and gives you a clear fixed price. No showroom, no pressure.</p>
        <div class="trust-chips">
          <span class="chip"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.9 6.3 6.9.6-5.2 4.6 1.6 6.8L12 17.3 5.8 20.9l1.6-6.8L2.2 8.9l6.9-.6z"/></svg>5-star rated locally</span>
          <span class="chip"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>Family-owned since 2020</span>
          <span class="chip"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 12-9 12s-9-5-9-12a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>We come to you</span>
        </div>
      </div>
      <div class="hx-photo reveal">
        <div class="hero-wide-card">
          <img src="/jackson-van-showroom.webp" width="1000" height="750" fetchpriority="high" alt="Jackson from Bay City Blinds with his branded mobile showroom van in Geelong" />
          <div class="badge-review"><span class="stars">★★★★★</span><span><b>5.0</b><br>42 reviews*</span></div>
          <div class="wide-pill"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 12-9 12s-9-5-9-12a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>Geelong · Surf Coast · Bellarine</div>
          <div class="name-tag">Jackson <span>· your local blinds guy</span></div>
        </div>
      </div>
      <aside id="quote" class="hx-form reveal">
        <LeadForm client:load />
      </aside>
    </div>
  </section>

  <TrustStrip />
  <Process />
  <Products />
  <Brands />
  <WhyUs />
  <Showroom />
  <MeetJackson />
  <Gallery />
  <Reviews />
  <ServiceAreas />

  <section class="block" id="faq">
    <div class="wrap">
      <div class="sec-head reveal">
        <p class="eyebrow">Good to know</p>
        <h2>Frequently asked questions</h2>
      </div>
      <Faq client:visible />
    </div>
  </section>

  <FinalCta />
</Layout>
