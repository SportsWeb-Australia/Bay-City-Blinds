---
import Layout from '../../layouts/Layout.astro';
import WhyUs from '../../components/WhyUs.astro';
import Reviews from '../../components/Reviews.astro';
import ServiceAreas from '../../components/ServiceAreas.astro';
import FinalCta from '../../components/FinalCta.astro';
import LeadForm from '../../components/LeadForm.tsx';
import { products } from '../../data/content';
import { localBusiness, serviceSchema, breadcrumb } from '../../data/schema';

export function getStaticPaths() {
  return products.map((p) => ({ params: { product: p.slug }, props: { p } }));
}
const { p } = Astro.props;

const title = `${p.name} Geelong | Free Measure & Quote | Bay City Blinds`;
const description = `${p.long.slice(0, 140)} Free in-home measure & quote across Geelong & the Bellarine.`;
const schemas = [
  localBusiness(),
  serviceSchema(),
  breadcrumb([
    { name: 'Home', url: '/' },
    { name: 'Blinds & Shutters', url: '/blinds' },
    { name: p.name, url: `/blinds/${p.slug}` },
  ]),
];
---
<Layout title={title} description={description} path={`/blinds/${p.slug}`} schemas={schemas}>
  <section class="hero">
    <div class="wrap">
      <div class="hero-copy reveal">
        <p class="eyebrow">Made to measure · Geelong &amp; the Bellarine</p>
        <h1>{p.name} in <span class="hl">Geelong</span></h1>
        <p class="sub">{p.long}</p>
        <a class="btn btn-primary btn-lg" href="#quote" style="margin-top:.6rem">Get my free quote →</a>
      </div>
      <div>
        <div class="hero-orb-wrap hero-orb-sub reveal">
          <div class="orb-ring" aria-hidden="true"></div>
          <img class="hero-orb" src="/jackson-orb.webp" width="1000" height="1000" alt={`${p.name} measured and installed by Bay City Blinds, Geelong`} />
          <div class="name-tag">Jackson <span>· your local blinds guy</span></div>
        </div>
      </div>
    </div>
    <div class="wrap" id="quote" style="padding-bottom:3rem;margin-top:-1rem">
      <div style="max-width:560px;margin-left:auto">
        <LeadForm client:load />
      </div>
    </div>
  </section>

  <WhyUs />
  <Reviews />
  <ServiceAreas />
  <FinalCta />
</Layout>
