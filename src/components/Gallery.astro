---
import { gallery } from '../data/content';
import { photo, photoMap } from '../data/photos';
---
<section class="block" id="gallery">
  <div class="wrap">
    <div class="sec-head reveal">
      <p class="eyebrow">Recent work</p>
      <h2>A look at the finished results</h2>
      <p>Real jobs, real homes across Geelong &amp; the Bellarine.</p>
    </div>
    <div class="gallery">
      {gallery.map((g, i) => (
        <a href="/free-measure-quote" aria-label={`${g.prod} in ${g.sub}`}>
          <img src={photo(`gallery-${i + 1}` as keyof typeof photoMap)} width="600" height="450" loading="lazy" alt={`${g.prod} installed in ${g.sub} by Bay City Blinds`} />
        </a>
      ))}
    </div>
  </div>
</section>
