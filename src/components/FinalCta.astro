---
import { site } from '../data/site';
---
<section class="block">
  <div class="wrap">
    <div class="final reveal">
      <p class="eyebrow" style="color:#bff0f6">Ready when you are</p>
      <h2>Let's get your windows sorted</h2>
      <p>Book your free in-home measure and quote today. Friendly, local, and no pressure — just honest advice and a clear price.</p>
      <div class="row">
        <a class="btn btn-white btn-lg" href="/free-measure-quote">Get my free quote →</a>
        <a class="btn btn-ghost btn-lg" href={site.phoneHref} style="background:transparent;color:#fff;border-color:rgba(255,255,255,.5)">Call Jackson: {site.phone}</a>
      </div>
    </div>
  </div>
</section>
