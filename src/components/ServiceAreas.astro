---
import { locations } from '../data/content';
---
<section class="block tint" id="areas">
  <div class="wrap">
    <div class="areas">
      <div class="reveal">
        <p class="eyebrow">Where we work</p>
        <h2 style="font-size:clamp(1.7rem,3vw,2.3rem);font-weight:800;margin:.4rem 0 .6rem">Proudly serving Geelong &amp; beyond</h2>
        <p style="color:var(--muted)">From the heart of Geelong to the Surf Coast, the Bellarine and out to Melbourne's west — if you're nearby, Jackson will come to you. Tap your area for a local free measure &amp; quote.</p>
        <div class="area-chips">
          {locations.map((l) => <a href={`/${l.slug}`}>{l.name}</a>)}
        </div>
        <a class="btn btn-primary btn-lg" href="/free-measure-quote" style="margin-top:1.5rem">Check my area &amp; book →</a>
      </div>
      <div class="map-box reveal" role="img" aria-label="Map of Bay City Blinds service area covering Geelong, the Surf Coast, Bellarine Peninsula and western Melbourne">
        <div class="pin">📍 Based in Geelong, VIC<small>Servicing a 60&nbsp;km radius — embed live Google Map here</small></div>
      </div>
    </div>
  </div>
</section>
