---
import { site } from '../data/site';
---
<div class="util">
  <div class="wrap">
    <span>★ Local &amp; family-owned in Geelong since {site.founded}</span>
    <span>
      <a href={site.phoneHref}>Call {site.phone}</a>
      <span class="dot">•</span>
      <a href={site.smsHref}>Text us</a>
      <span class="dot">•</span>
      <a href="/free-measure-quote">Free measure &amp; quote →</a>
    </span>
  </div>
</div>
<header>
  <nav class="nav">
    <a class="brand" href="/">
      <span class="logo-mark" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none"><path d="M4 20V8l4-3v15M10 20V5l4 3v12M16 20V9l4 2v9" stroke="#25C9DD" stroke-width="1.8" stroke-linejoin="round"/></svg>
      </span>
      <span>Bay City Blinds<small>Geelong · mobile showroom</small></span>
    </a>
    <div class="nav-links">
      <a href="/blinds">Blinds &amp; Shutters</a>
      <a href="/#process">How it works</a>
      <a href="/#areas">Service areas</a>
      <a href="/reviews">Reviews</a>
      <a href="/#faq">FAQ</a>
    </div>
    <div class="nav-cta">
      <a class="nav-phone" href={site.phoneHref}>{site.phone}</a>
      <a class="btn btn-primary" href="/free-measure-quote">Free quote</a>
    </div>
  </nav>
</header>
